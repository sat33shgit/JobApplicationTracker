{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignore": [
      "dist",
      "node_modules",
      "src/components/ui",
      "src/components/figma",
      "src/figma-shim.ts",
      "src/figma-shim.d.ts",
      "src/global.d.ts",
      "src/**/*.css"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "useKeyWithClickEvents": "warn",
        "useSemanticElements": "warn",
        "noLabelWithoutControl": "warn",
        "noRedundantAlt": "warn",
        "useAltText": "warn",
        "useButtonType": "warn"
      },
      "complexity": {
        "noForEach": "warn",
        "useOptionalChain": "warn"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn",
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "warn",
        "noAssignInExpressions": "warn"
      },
      "style": {
        "useImportType": "warn",
        "useNumberNamespace": "warn",
        "useTemplate": "warn",
        "noNonNullAssertion": "warn",
        "useSingleVarDeclarator": "warn",
        "noInferrableTypes": "warn"
      }
    }
  },
  "organizeImports": {
    "enabled": true
  }
}
